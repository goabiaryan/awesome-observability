# ============================================================================
# LLM Observability - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================================================
# OpenTelemetry / OTLP Configuration (Primary)
# ============================================================================
OTEL_SDK_DISABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_TIMEOUT=10
OTEL_SERVICE_NAME=llm-agent-app
OTEL_SERVICE_VERSION=1.0.0

# ============================================================================
# OTLP Backend Selection (choose one)
# ============================================================================
OTLP_BACKEND=signoz

SIGNOZ_ENDPOINT=http://localhost:4317
SIGNOZ_ENABLED=true

UPTRACE_DSN=https://api.uptrace.dev

JAEGER_ENDPOINT=http://localhost:4317

# ============================================================================
# abidex Configuration (Zero-Code Agent Tracing)
# ============================================================================
ABIDEX_ENABLED=true
ABIDEX_EXPORT_INTERVAL=5
ABIDEX_BATCH_SIZE=512

# ============================================================================
# Optional: Langfuse (for prompt management & evals)
# ============================================================================
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ============================================================================
# Optional: Arize Phoenix (for drift detection & advanced evals)
# ============================================================================
PHOENIX_ENABLED=false
PHOENIX_HOST=http://localhost:6006
PHOENIX_ENABLE_DRIFT_DETECTION=false

# ============================================================================
# LLM Provider APIs
# ============================================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=
GOOGLE_API_KEY=

# ============================================================================
# Optional: Advanced Observability Backends
# ============================================================================
LANGSMITH_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

HELICONE_ENABLED=false
HELICONE_API_KEY=

DATADOG_ENABLED=false
DATADOG_API_KEY=
DATADOG_APP_KEY=

# ============================================================================
# Database Configuration (for Langfuse if enabled)
# ============================================================================
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=change_me_production
POSTGRES_DB=langfuse
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================================================
# Redis Configuration (for caching)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ============================================================================
# Agent & Evaluation Configuration
# ============================================================================
LOG_LEVEL=INFO
ENVIRONMENT=production
APP_NAME=llm-agent-app
APP_VERSION=1.0.0

DAILY_BUDGET_USD=100.0
BUDGET_ALERT_THRESHOLD=0.8
MAX_TOKENS_PER_REQUEST=4000
MAX_ITERATIONS_AGENT=15

HALLUCINATION_THRESHOLD=0.85
FAITHFULNESS_THRESHOLD=0.80
ANSWER_RELEVANCY_THRESHOLD=0.75

# ============================================================================
# Monitoring & Alerting
# ============================================================================
PROMETHEUS_PUSH_INTERVAL=30
PROMETHEUS_RETENTION=30d
ALERTMANAGER_ENABLED=true

# ============================================================================
# External Integrations (Optional)
# ============================================================================
SLACK_WEBHOOK_URL=
PAGERDUTY_API_KEY=

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_HALLUCINATION_DETECTION=true
ENABLE_DRIFT_DETECTION=true
ENABLE_COST_TRACKING=true
ENABLE_BATCH_EVALUATION=true

# ============================================================================
# Debug Configuration
# ============================================================================
DEBUG_MODE=false
VERBOSE_LOGGING=false
PRINT_TOKEN_USAGE=true
PRINT_COSTS=true
SAVE_TRACES_TO_FILE=false
